import pandas as pd
import matplotlib.pyplot as plt
import difflib

from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.metrics.pairwise import cosine_similarity

# Load dataset
df = pd.read_csv("udemy_course_data.csv")

# Visualization
df['subject'].value_counts().plot(kind='bar')
plt.title("Course Category Distribution")
plt.xlabel("Category")
plt.ylabel("Number of Courses")
plt.show()

df['level'].value_counts().plot(kind='pie', autopct='%1.1f%%')
plt.title("Course Level Distribution")
plt.show()


print("First 5 rows:")
print(df.head())

print("\nShape of dataset:")
print(df.shape)

print("\nColumn Names:")
print(df.columns)

print("\nDataset Info:")
print(df.info())

print("\nMissing Values:")
print(df.isnull().sum())

# Remove duplicates
df = df.drop_duplicates()

# Select useful columns
df = df[['course_title', 'subject', 'level']]

# Combine features
df['combined_features'] = df['course_title'] + " " + df['subject'] + " " + df['level']

# Reset index
df = df.reset_index(drop=True)

print(df.head())



# TF-IDF
tfidf = TfidfVectorizer(stop_words='english')
tfidf_matrix = tfidf.fit_transform(df['combined_features'])

print("TF-IDF Matrix Shape:", tfidf_matrix.shape)

# Cosine Similarity
cosine_sim = cosine_similarity(tfidf_matrix)
print("Cosine Similarity Matrix Shape:", cosine_sim.shape)

# Index mapping
indices = pd.Series(df.index, index=df['course_title']).drop_duplicates()

# Recommendation function
def recommend(course_name):

    if course_name not in df['course_title'].values:
        print("Course not found!")
        close_matches = difflib.get_close_matches(course_name, df['course_title'], n=3)
        print("Did you mean:", close_matches)
        return

    idx = indices[course_name]

    similarity_scores = list(enumerate(cosine_sim[idx]))

    sorted_scores = sorted(similarity_scores, key=lambda x: x[1], reverse=True)

    print("\nGenerating Recommendations...\n")
    print("Top 5 Recommended Courses:\n")

    recommended = sorted_scores[1:20]

    recommended_courses = [df.iloc[i[0]] for i in recommended]

    recommended_df = pd.DataFrame(recommended_courses)

    if 'num_subscribers' in df.columns:
        recommended_df = recommended_df.sort_values(by="num_subscribers", ascending=False)

    print("\nTop 5 Recommended Courses:\n")

    for i in range(5):
        print("-", recommended_df.iloc[i]['course_title'])

# Call function
course_name = input("Enter course name: ")
recommend(course_name)
